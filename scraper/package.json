{
  "name": "zaiquest-scraper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "scrape:taroto": "tsx src/index.ts --source taroto",
    "scrape:panasonic": "tsx src/index.ts --source panasonic",
    "scrape:toshiba": "tsx src/index.ts --source toshiba",
    "scrape:mitsubishi-wink": "tsx src/index.ts --source mitsubishi-wink",
    "scrape:all": "tsx src/index.ts --source all",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "cheerio": "^1.0.0",
    "playwright": "^1.50.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
